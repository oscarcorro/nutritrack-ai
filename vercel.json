{
  "rewrites": [
    { "source": "/((?!assets/|icon\\.svg|favicon\\.svg|manifest\\.json|sw\\.js|workbox-.*\\.js|registerSW\\.js|robots\\.txt).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
